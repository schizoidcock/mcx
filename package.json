{
  "name": "mcx",
  "version": "0.1.0",
  "private": true,
  "description": "MCP Code eXecution Framework",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "biome lint packages/",
    "clean": "turbo run clean && rm -rf node_modules",
    "mcx": "bun ./packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.2.0",
  "dependencies": {
    "@ff-labs/fff-bun": "link:@ff-labs/fff-bun",
    "@m234/nerd-fonts": "^0.5.1",
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui-ui/toast": "^0.0.5",
    "@opentui/core": "^0.1.100",
    "@opentui/react": "^0.1.100",
    "@papicandela/mcx-adapters": "workspace:*",
    "@papicandela/mcx-core": "workspace:*",
    "nia-onboarding-agent": "^1.0.2"
  }
}
