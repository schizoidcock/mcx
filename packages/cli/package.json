{
  "name": "@papicandela/mcx-cli",
  "version": "0.3.15",
  "description": "CLI for the MCX framework - MCP Code Execution",
  "author": "papicandela",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/schizoidcock/mcx"
  },
  "type": "module",
  "bin": {
    "mcx": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --env disable --external @opentui/core --external @opentui/react --external @opentui-ui/dialog --external @opentui-ui/toast --external react --external react-reconciler && bun run add-shebang",
    "add-shebang": "bun -e \"const f=Bun.file('dist/index.js');const c=await f.text();if(!c.startsWith('#!'))await Bun.write('dist/index.js','#!/usr/bin/env bun\\n'+c)\"",
    "dev": "bun --watch dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ff-labs/fff-bun": "^0.4.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui-ui/toast": "^0.0.5",
    "@opentui/core": "^0.1.81",
    "@opentui/react": "^0.1.81",
    "@papicandela/mcx-core": "workspace:*",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  },
  "optionalDependencies": {
    "@ff-labs/fff-bin-darwin-arm64": "0.4.2",
    "@ff-labs/fff-bin-darwin-x64": "0.4.2",
    "@ff-labs/fff-bin-linux-x64-gnu": "0.4.2",
    "@ff-labs/fff-bin-win32-x64": "0.4.2"
  },
  "keywords": [
    "mcx",
    "cli",
    "mcp",
    "claude"
  ]
}
